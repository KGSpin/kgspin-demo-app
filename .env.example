# kgspin-demo — example environment file
#
# Copy to .env and fill in the values for the landers you want to run.
# Every variable the Python source reads is listed below. Variables
# marked `# required` have no safe default. Variables marked `# optional`
# have a working default (see README.md for the default value).
#
# Shell-only variables used by scripts/start-demo.sh are grouped at the
# bottom — they do not need to be set for `uv run` invocations.

# ---- Admin service ------------------------------------------------------
# Required if you want landers to register their output with admin or
# the Intelligence tab to resolve the corpus from admin.
KGSPIN_ADMIN_URL="http://127.0.0.1:8750"  # optional — defaults to localhost:8750

# ---- Corpus root --------------------------------------------------------
# Where landers write raw artifacts on disk.
# KGSPIN_CORPUS_ROOT="$HOME/.kgspin/corpus"  # optional

# ---- SEC EDGAR lander ---------------------------------------------------
# An email address works. SEC requires all EDGAR consumers to identify
# themselves. Used by `kgspin-demo-lander-sec` and the Intelligence tab.
EDGAR_IDENTITY=""                            # required for SEC lander
# SEC_USER_AGENT=""                          # optional — legacy alias, ignored if EDGAR_IDENTITY is set

# ---- News APIs ----------------------------------------------------------
# Marketaux: free tier 100 req/day — https://www.marketaux.com/
MARKETAUX_API_KEY=""                         # required for Marketaux lander
# NewsAPI.org: free tier available — https://newsapi.org/register
NEWSAPI_KEY=""                               # required for NewsAPI lander

# ---- ClinicalTrials.gov v2 ----------------------------------------------
# The v2 API is public. Key is optional; only set if you need higher rate limits.
# CLINICAL_TRIALS_API_KEY=""                 # optional

# ---- Gemini / LLM columns in the compare UI -----------------------------
# Without one of these, the LLM columns surface an error; the KGSpin
# columns still run normally.
GEMINI_API_KEY=""                            # optional
# GOOGLE_GENAI_API_KEY=""                    # optional — alternative name, read as a fallback

# ---- Compare-UI server --------------------------------------------------
# PORT=8080                                  # optional — port the compare-UI server binds to

# ---- Bundle-resource API server (kgspin_demo.api.server) ----------------
# Only relevant if you run that module directly. The compare UI does not
# use this server.
# KGEN_BUNDLES_DIR=".bundles"                # optional — directory of .bundle.json files
# KGEN_DEFAULT_BUNDLE=""                     # optional — default bundle id for the compare-UI pipelines
# CORS_ORIGINS="*"                           # optional — comma-separated CORS allow-list
# KGEN_API_KEY=""                            # optional — X-API-Key shared secret; if set, unauthenticated requests are rejected

# ---- scripts/start-demo.sh launcher (shell-only) ------------------------
# These are read by the bash launcher, not by the Python source.
# KGSPIN_ADMIN_PATH="../kgspin-admin"        # optional — where the launcher starts admin from
# KGSPIN_ADMIN_LOG="/tmp/kgspin-admin.log"   # optional — where the background admin's stdout/stderr go
